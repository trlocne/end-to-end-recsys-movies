FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY workflows/steps/data_prep/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ /app/src/
COPY workflows/steps/data_prep/main.py /app/main.py

ENV PYTHONPATH=/app

ENTRYPOINT ["python", "/app/main.py"]
